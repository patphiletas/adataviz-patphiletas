  return (
    <div>
      <h2><em>{theme.name}</em></h2>

    <ul>
      {theme.skills.map((skill, index) => (
        <div key={index}>
          <h4>{skill.label}</h4>
          <select
            value={skill.validation}
            onChange={(e) =>
              updateSkillStatus(index, e.target.value)
            }
          >
            <option value="OK">✅ OK</option>
            <option value="PROGRESS">📈 PROGRESS</option>
            <option value="KO">☠️ KO</option>
          </select>
          <h3>----------------</h3>
        </div>
      ))}
