import { useEffect, useState } from "react";

export default function ThemeSkills({ themeId }) {
  
  const [theme, setTheme] = useState(null);

  useEffect(() => {
    fetch(`http://localhost:3000/themes/${themeId}`)
      .then(res => res.json())
      .then(data => setTheme(data[0]));
  }, [themeId]);

  const updateSkillStatus = async (skillIndex, status) => {
    const res = await fetch(
      `http://localhost:3000/themes/${themeId}/skills/${skillIndex}/${status}`,
      { method: "PUT" }
    );
    const updatedSkills = await res.json();
    setTheme({ ...theme, skills: updatedSkills });
  };

  const deleteTheme = async () => {
    await fetch(`http://localhost:3000/themes/${themeId}`, {
      method: "DELETE",
    });
    setTheme(null);
  };
